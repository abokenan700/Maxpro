generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  DRAFT
  PLACED
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum InventoryStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

enum PaymentStatus {
  REQUIRES_ACTION
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum NotificationChannel {
  PUSH
  SMS
  EMAIL
  WHATSAPP
}

enum CmsPlacement {
  HOME_HERO
  PRODUCT_STORY
  CHECKOUT_TRUST
  ONBOARDING
}

model User {
  id            String         @id @default(cuid())
  phone         String         @unique
  email         String?        @unique
  name          String
  passwordHash  String?
  loyaltyPoints Int            @default(0)
  walletBalance Decimal        @default(0) @db.Decimal(12, 2)
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  notifications Notification[]
  walletLedger  WalletLedger[]
  loyaltyLedger LoyaltyLedger[]
  auditLogs     AuditLog[]
  sessions      Session[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([phone])
  @@index([createdAt])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshHash  String   @unique
  deviceName   String?
  ipHash       String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())

  @@index([userId, expiresAt])
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String
  recipient   String
  phone       String
  city        String
  district    String
  line1       String
  geoLat      Decimal? @db.Decimal(9, 6)
  geoLng      Decimal? @db.Decimal(9, 6)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, isDefault])
  @@index([city, district])
}

model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  nameAr    String
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())

  @@index([sortOrder])
}

model Brand {
  id        String    @id @default(cuid())
  slug      String    @unique
  nameAr    String
  storyAr   String?
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id          String          @id @default(cuid())
  sku         String          @unique
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id])
  brandId     String?
  brand       Brand?          @relation(fields: [brandId], references: [id])
  nameAr      String
  storyAr     String
  price       Decimal         @db.Decimal(12, 2)
  compareAt   Decimal?        @db.Decimal(12, 2)
  status      InventoryStatus @default(IN_STOCK)
  searchText  String
  variants    Variant[]
  media       Media[]
  reviews     Review[]
  orderItems  OrderItem[]
  analytics   ProductAnalytics[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([categoryId, status])
  @@index([brandId])
  @@index([price])
  @@index([searchText])
}

model Variant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String   @unique
  colorHex  String
  size      String?
  stock     Int      @default(0)
  reserved  Int      @default(0)

  @@index([productId, colorHex])
  @@index([stock])
}

model Media {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altAr     String
  kind      String  @default("IMAGE")
  sortOrder Int     @default(0)

  @@index([productId, sortOrder])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  status          OrderStatus @default(DRAFT)
  subtotal        Decimal     @db.Decimal(12, 2)
  discount        Decimal     @default(0) @db.Decimal(12, 2)
  shipping        Decimal     @default(0) @db.Decimal(12, 2)
  tax             Decimal     @default(0) @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  items           OrderItem[]
  payments        Payment[]
  couponId        String?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  deliveryWindow  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId, status, createdAt])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  variantId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider      String
  providerRef   String        @unique
  amount        Decimal       @db.Decimal(12, 2)
  currency      String        @default("SAR")
  status        PaymentStatus @default(REQUIRES_ACTION)
  riskDecision  String?
  createdAt     DateTime      @default(now())
  capturedAt    DateTime?

  @@index([orderId, status])
  @@index([provider, status])
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  amountOff   Decimal? @db.Decimal(12, 2)
  percentOff  Int?
  startsAt    DateTime
  endsAt      DateTime
  maxUses     Int?
  usedCount   Int      @default(0)
  orders      Order[]

  @@index([code, startsAt, endsAt])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int
  bodyAr    String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([productId, rating])
  @@index([userId])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   NotificationChannel @default(PUSH)
  titleAr   String
  bodyAr    String
  readAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([userId, readAt, createdAt])
  @@index([channel, createdAt])
}

model WalletLedger {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  reasonAr  String
  reference String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model LoyaltyLedger {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points    Int
  reasonAr  String
  reference String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model ProductAnalytics {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  impressions Int      @default(0)
  addToCarts  Int      @default(0)
  purchases   Int      @default(0)
  revenue     Decimal  @default(0) @db.Decimal(14, 2)
  date        DateTime

  @@unique([productId, date])
  @@index([date])
}

model CmsBlock {
  id          String       @id @default(cuid())
  placement   CmsPlacement
  titleAr     String
  bodyAr      String
  mediaUrl    String?
  ctaLabelAr  String?
  ctaHref     String?
  isActive    Boolean      @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())

  @@index([placement, isActive, sortOrder])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId])
}
